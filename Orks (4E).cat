        <selectionEntry type="upgrade" import="true" name="Bomb Squig" hidden="false" id="2f73-6be2-ec1d-8ace" sortIndex="2">
          <profiles>
            <profile name="Bomb Squig" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="9ad3-ae6a-c3e9-ee9e">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Tankbusta may release a Bomb-squig instead of shooting. Roll a dice. On a roll of 2+ the Bomb-squig will run straight into the nearest enemy vehicle within 18&quot; and detonate, causing a S8 hit on the section of the vehicle facing the Tankbusta. On a roll of 1 the squig will run straight into the nearest friendly vehicle within 18&quot; and detonate there instead. Remove the Bomb-squig once it has been released, whether or not they are in range of their target. Bomb-squig models are purely decorative and do not have a profile.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
          <constraints>
            <constraint type="max" value="3" field="selections" scope="parent" shared="true" id="72d3-cef0-b901-bec1" includeChildSelections="false" automatic="true"/>
          </constraints>
        </selectionEntry>
