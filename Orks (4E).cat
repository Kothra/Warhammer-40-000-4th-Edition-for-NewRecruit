            </selectionEntryGroup>
          </selectionEntryGroups>
        </selectionEntryGroup>
        <selectionEntryGroup name="Big Gun" id="b893-1ab4-00c1-5ffa" hidden="false" sortIndex="2">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8136-df81-ae48-0911" includeChildSelections="false" automatic="true"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Zzap Gun" hidden="false" id="3cf9-8645-da5d-0769">
              <profiles>
                <profile name="Zzap Gun" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="6dee-c661-672f-b456">
                  <characteristics>
                    <characteristic name="Range" typeId="52616e676523232344415441232323">36&quot;</characteristic>
                    <characteristic name="Strength" typeId="537472656e67746823232344415441232323">2D6</characteristic>
                    <characteristic name="AP" typeId="4.1502323234441545e+23">2</characteristic>
                    <characteristic name="Type" typeId="8b10-045a-f593-605e">Heavy 1</characteristic>
                    <characteristic name="Info" typeId="33e9-27bd-77e4-401d">Each time a zzap gun battery is fired, after declaring a target but before rolling to hit, roll 2D6 to determine its Strength. If the roll is above 10, one of the Gretchin crew is killed but the shot is still fired, counting as Strength 10. When they score glancing or penetrating hits against vehicles, zzap guns automatically cause a Crew Shaken result in addition to any other effects.
On vehicles, zzap guns are never counted as defensive weapons. If the Strength roll is higher than 10 there are no negative effects.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
              </costs>
            </selectionEntry>
