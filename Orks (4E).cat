            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="49e5-fa24-e5d5-d011-min" includeChildSelections="false" automatic="true"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="49e5-fa24-e5d5-d011-max" includeChildSelections="false" automatic="true"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Slugga and Choppa" hidden="false" id="5057-9ee7-a08c-b877" sortIndex="2">
              <infoLinks>
                <infoLink name="Slugga" id="d7ad-3843-e191-6cdc" hidden="false" type="profile" targetId="f25c-07d3-3d67-804d"/>
                <infoLink name="Choppa" id="55d7-e091-bdb6-e8bb" hidden="false" type="profile" targetId="64ba-af59-2f19-e3df"/>
              </infoLinks>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <constraints>
        <constraint type="max" value="3" field="selections" scope="root-entry" shared="true" id="30d8-d1ef-bf43-cccf" includeChildSelections="true" automatic="false"/>
      </constraints>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
      </costs>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Mek&apos;s Tools" hidden="false" id="de17-7c39-2de3-f755">
      <constraints>
        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="fcfe-a177-0639-ed06-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fcfe-a177-0639-ed06-max" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="Mek&apos;s Tools" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="32f1-2ed9-8174-82a5">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">If a Mekboy or Big Mek is inside (or in base contact with) a vehicle at the beginning of his Shooting phase, he can attempt to repair a single Weapon Destroyed or Immobilised result instead of shooting. Roll a D6 - on a roll of a 4+ the result is negated. This could allow a previously destroyed weapon to fire in that Shooting phase. On a roll of a 1, the Mek gets a bit carried away and the vehicle counts as shaken.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Grot Oiler" hidden="false" id="2784-a76e-e4cf-8f7a">
      <profiles>
        <profile name="Grot Oiler" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4b8c-bf2a-4795-94a8">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A grot oiler allows a Mek to re-roll a failed Mek&apos;s Tools repair roll. Remove the oiler model once he has been used. Oiler models are purely decorative and are always ignored for game purposes. Just move them to one side if they become a problem.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Painboy" hidden="false" id="99d6-44be-18d9-3770">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Dok&apos;s Tools" hidden="false" id="4be2-b821-a29c-6c39">
          <profiles>
            <profile name="Dok&apos;s Tools" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="ca36-6c89-71e2-d833">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Painboy confers the Feel No Pain special rule to his unit.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="6663-2593-52ef-3686-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6663-2593-52ef-3686-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="&apos;Urty Syringe" hidden="false" id="8ca4-f786-29cb-3567">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="00f1-2874-b957-c0ce-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="00f1-2874-b957-c0ce-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="&apos;Urty Syringe" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="ef7c-7714-01dc-62ed">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">An &apos;urty syringe is a Poisoned Weapon that always wounds on a 4+</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <modifiers>
        <modifier type="set" value="false" field="hidden">
          <conditionGroups>
            <conditionGroup type="and">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="99d6-44be-18d9-3770" shared="true" childName="Painboy" includeChildSelections="true"/>
                <condition type="equalTo" value="0" field="selections" scope="parent" childId="99d6-44be-18d9-3770" shared="true" childName="Painboy" includeChildSelections="true"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
          <comment>CHANGE TO TRUE WHEN UNIT COUNT BUG FIXED</comment>
        </modifier>
        <modifier type="set" value="Painboy" field="name" scope="parent"/>
      </modifiers>
      <profiles>
        <profile name="Painboy" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="cb56-fa58-6df4-25e8">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">4</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">2</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">4</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">4</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">2</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">3</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">3</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">7</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">6+</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Grot Orderly" hidden="false" id="bc0e-e29f-98c6-5715">
      <profiles>
        <profile name="Grot Orderly" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="2f7a-66f6-fb62-894b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A grot orderly allows a Painboy&apos;s unit to re-roll a single Feel No Pain roll. Remove the orderly model once he has been used. Orderly models are purely decorative and are always ignored for game purposes. Just move them to one side if they become a problem.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Cybork Bodies" hidden="true" id="866a-9bb3-3f78-4db2">
      <profiles>
        <profile name="Cybork Bodies" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="921e-6d20-60be-a2bf">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">All models in the unit are given a cybork body and so have a 5+ Invulnerable Save.
Unique characters can not be given cybork bodies.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <comment>from Painboyz</comment>
      <modifiers>
        <modifier type="increment" value="5" field="4deb-313d-6685-f48b">
          <repeats>
            <repeat value="1" repeats="1" field="selections" scope="root-entry" childId="model" shared="true" roundUp="false" includeChildSelections="true" childName="model"/>
          </repeats>
        </modifier>
        <modifier type="set" value="false" field="hidden">
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="99d6-44be-18d9-3770" shared="true" includeChildSelections="true" childName="Painboy"/>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4eac-7590-c747-4341" shared="true" includeChildSelections="true" childName="Mad Dok Grotsnik"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
        </modifier>
        <modifier type="decrement" value="5" field="4deb-313d-6685-f48b">
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="8df5-0b46-365b-1347" shared="true" includeChildSelections="true" childName="Bozz Zagstruk"/>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="74e5-f398-0edd-8273" shared="true" includeChildSelections="true" childName="Boss Snikrot"/>
              </conditions>
