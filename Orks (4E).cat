        </modifier>
      </modifiers>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8058-4aed-4a60-7557" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Grot Riggers" hidden="false" id="d26b-e432-6ef1-fe05">
      <profiles>
        <profile name="Grot Riggers" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="058c-85c3-4692-bdf7">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">An Immobilised Ork vehicle with Grot riggers may roll a dice during the ork shooting phase - on a 4+ the Immobilised result is negated. The vehicle is able to start moving next turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e50c-27d1-f567-9866" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Armour Plates" hidden="false" id="0280-0df5-e2b6-ef32">
      <profiles>
        <profile name="Armour Plates" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="f4cd-e426-d7b9-2c9b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A vehicle with armour plates treats &apos;Crew Stunned&apos; results as &apos;Crew Shaken&apos; results instead.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="10f7-4d78-9339-3de4" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Grabbin&apos; Klaw" hidden="false" id="bebd-188e-1bf7-ef93">
      <profiles>
        <profile name="Grabbin&apos; Klaw" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="367f-62f6-100a-9d9e">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">At the beginning of the enemy Movement phase, nominate an enemy vehicle within 2&quot; of the grabbin&apos; klaw. On a roll of 4+ that vehicle may not move this turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5483-0673-cc4d-1a34" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Boarding Plank" hidden="false" id="1588-b523-ce5b-8579">
      <profiles>
        <profile name="Boarding Plank" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="98ee-cb4e-2e21-91ed">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A boarding plank allows a single embarked Ork to make its close combat attacks against an enemy vehicle within 2&quot; exactly as if the Ork were disembarked and charging, provided neither vehicle has moved more than 12&quot;.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6509-6988-3502-0340" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Red Paint Job" hidden="false" id="e132-c17b-4dda-8a94">
      <profiles>
        <profile name="Red Paint Job" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="3222-2d26-0b9c-c9fe">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Ork vehicles with red paint jobs add +1 to their move in the Movement phase but do not incur penalties for this extra inch. For example, a vehicle could move 13&quot; and still count as moving 12&quot;.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="34b5-acc7-dac1-874e" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Reinforced Ram" hidden="false" id="f75b-fc93-e46a-5076">
      <profiles>
        <profile name="Reinforced Ram" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6b07-2472-8832-decf">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A vehicle with a reinforced ram can Tank Shock, and treats its front armour as two higher than normal when resolving Death or Glory attacks (to a maximum of 14). Furthermore the vehicle may re-roll Dangerous Terrain tests.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4b79-b0d4-49be-39a8" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Stikkbomb Chukka" hidden="false" id="4bf1-d1ea-f892-454e">
      <profiles>
        <profile name="Stikkbomb Chukka" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="d275-72ae-0b20-907f">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any unit disembarking from a vehicle with a stikkbomb chukka is treated as having stikkbombs if they charge into combat that turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="536d-2ebf-a9a3-e2b3" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Wreckin&apos; Ball" hidden="false" id="8f01-2af7-1e7d-17ec">
      <profiles>
        <profile name="Wreckin&apos; Ball" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4879-5b8c-3f68-6130">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A vehicle with a wreckin&apos; ball causes a Strength 9 hit upon one unengaged enemy unit within 2&quot; of the wreckin&apos; ball at the beginning of the Assault phase on a roll of 4+. The vehicle may not use its wreckin&apos; ball if it has moved more than 12&quot; that turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5274-f62e-619c-4a85" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="&apos;Ard Case" hidden="false" id="2f6c-b721-d7b2-b800">
      <profiles>
        <profile name="&apos;Ard Case" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8f59-d764-6048-9451">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A vehicle with an &apos;ard case no longer counts as Open-Topped. Note that this affects its Access Points and Fire Points as detailed in the appropriate entry.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="23ec-07ce-316a-ad3d" includeChildSelections="false"/>
      </constraints>
      <modifiers>
        <modifier type="replace" field="5.479706523232345e+27" scope="parent" affects="self.entries.profiles.Vehicle" arg="Open-topped"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="model" import="true" name="Runtherd" hidden="false" id="5cf9-21a3-8d27-df49">
      <profiles>
        <profile name="Runtherd" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="f1d1-9d27-43e2-b06f">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">4</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">2</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">3</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">4</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">1</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">2</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">2</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">7</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">6+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntryGroups>
        <selectionEntryGroup name="Tools" id="6eef-fc76-8957-53e7" hidden="false" flatten="true" defaultSelectionEntryId="16b7-b4d4-0e0c-591a" sortIndex="1">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Grabba Stikk" hidden="false" id="16b7-b4d4-0e0c-591a" sortIndex="1">
              <profiles>
                <profile name="Grabba Stikk" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="2696-978f-7452-2803">
                  <characteristics>
                    <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A model with a grabba stikk attacks normally but each Assault phase he can cause a single model in base contact to lose an Attack (to a minimum of 1).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Grot-prod" hidden="false" id="6b30-2acb-3611-8383" sortIndex="2">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
              </costs>
              <profiles>
                <profile name="Grot-prod" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="8e90-5122-3eaf-be79">
                  <characteristics>
                    <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A model with a grot-prod counts as having a Poisoned Weapon that always wounds on 4+.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="6631-ed9a-e30d-f06f-min" includeChildSelections="false" automatic="true"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6631-ed9a-e30d-f06f-max" includeChildSelections="false" automatic="true"/>
          </constraints>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <entryLinks>
        <entryLink import="true" name="Slugga" hidden="false" id="f873-10ce-ff18-b237" type="selectionEntry" targetId="bb6e-cadb-f06e-fb59" sortIndex="2">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="e718-53e5-99c3-ff5e-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e718-53e5-99c3-ff5e-max" includeChildSelections="false"/>
          </constraints>
        </entryLink>
      </entryLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Squig Hound" hidden="false" id="3075-5139-7cee-67fd" sortIndex="3">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="7a19-65f8-fbd2-cfd4-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7a19-65f8-fbd2-cfd4-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Squig Hound" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="40c3-2085-1cee-0281">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Each time a unit with a squig-hound fails a Morale test it may remove D3 Gretchin models to re-roll that Morale test.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
      </costs>
      <infoLinks>
        <infoLink name="Furious Charge" id="e337-b4a8-a65c-cf94" hidden="false" type="rule" targetId="d9b8-5d21-f44f-80d3"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Nob" hidden="false" id="7f92-777b-a0e1-ae36">
      <profiles>
