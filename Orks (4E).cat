      </entryLinks>
      <rules>
        <rule name="Glory Hogs" id="6446-5358-8bcb-38ec" hidden="false">
          <description>Tankbustas must always attempt to shoot at and/or assault an enemy vehicle if there is one in line of sight, regardless of range. If there is no visible vehicle target, the Tankbustas may select a target as normal.</description>
        </rule>
      </rules>
    </selectionEntry>
