    <selectionEntry type="upgrade" import="true" name="Warbike" hidden="false" id="acde-03bd-9855-7585">
      <profiles>
        <profile name="Warbike" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="79d8-097b-471c-dc79">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any model mounted on a Warbike ads 1 to his Toughnes (though not for determining Instant Death), modifies his troop type to Bike, gains a 4+ Armour Save and the Exhaust Cloud special rule. Warbikes have twin-linked dakkaguns mounted.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="replace" value="Bike" field="556e6974205479706523232344415441232323" affects="profiles.Unit" arg="Infantry" scope="parent"/>
        <modifier type="append" value="(6)" field="5.423232344415441e+21" affects="profiles.Unit" arg="Infantry" scope="parent">
