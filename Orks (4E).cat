                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d737-7252-e8cd-0337" includeChildSelections="false"/>
                  </constraints>
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="20"/>
                  </costs>
                  <profiles>
                    <profile name="Deff Rolla" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a72f-4d73-0357-e132">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Battlewagon with a deff rolla may re-roll Dangerous Terrain tests. Any Tank Shock made by a Battlewagon with a deff rolla causes D6 Strength 10 hits on the victim unit. If the unit elects to make a Death or Glory attack, it takes a further D6 Strength 10 hits in addition to the usual effects.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                </selectionEntry>
              </selectionEntries>
              <entryLinks>
                <entryLink import="true" name="Reinforced Ram" hidden="false" id="c748-fc1a-400e-c6ff" type="selectionEntry" targetId="f75b-fc93-e46a-5076">
                  <costs>
