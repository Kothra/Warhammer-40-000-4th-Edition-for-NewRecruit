      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="155"/>
      </costs>
      <rules>
        <rule name="Doomed" id="1dce-4b9c-5ca7-3cfe" hidden="false">
          <description>At the end of every game, Yriel suffers one automatic wound from  his own weapon. Yyriel may take his forceshield save as normal.</description>
        </rule>
        <rule name="Master Strategist" id="c28b-a868-6094-26ba" hidden="false">
          <description>Any Eldar army including one or more Autarchs has a strategy rating of 4. While the Autarch is alive, you may shoose to add 1 to your rolls for reserves, regardless of whether he is in play or not (a roll of 1 always counts as a failure).</description>
        </rule>
      </rules>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="ba80-5f80-f941-dfd6" includeChildSelections="true"/>
      </constraints>
    </selectionEntry>
