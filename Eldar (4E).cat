  <sharedRules>
    <rule name="Disciples" id="da90-6e55-03b8-8807" hidden="false">
      <description>If the Phoenix Lord is leading a squad of their Aspect, then the whole squad becomes Fearless. Phoenix Lords cannot join Aspect Warrior squads that are not of their Aspect. Note that if a squad has two of the same Exarch power, they are not cumulative.</description>
    </rule>
    <rule name="Wraithsight" id="6e32-3694-0502-f76d" hidden="false">
      <description>At the start of the Eldar turn, roll a D6 for each unit with Wraithsight that is not within 6&quot; of a friendly psyker. On a roll of 1, the unit is inactive until the end of the turn. Inactive models may not move, shoot, assault, or attack in close combat, and are automatically hit in close combat.</description>
    </rule>
  </sharedRules>
  <categoryEntries>
    <categoryEntry name="Phoenix Lord" id="d4b4-b1e7-a460-538c" hidden="false"/>
  </categoryEntries>
