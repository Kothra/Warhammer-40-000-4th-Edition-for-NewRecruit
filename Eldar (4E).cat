    <selectionEntry type="model" import="true" name="The Avatar of Khaine" hidden="false" id="a181-9d61-7bd4-eafc">
      <categoryLinks>
        <categoryLink name="HQ" hidden="false" id="0706-21ff-1b43-8d21" targetId="0d45-9523-cfd8-4efd" primary="true"/>
        <categoryLink name="Character" hidden="false" id="6ff8-764c-1385-99e1" targetId="c918-96c1-1ff1-3df1" primary="false"/>
      </categoryLinks>
      <profiles>
        <profile name="The Avatar of Khaine" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="53fb-7f0d-9c1f-67f1">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Monstrous Creature</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">10</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">5</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">6</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">6</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">4</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">6</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">4</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">3+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Daemon" id="f434-875d-40b9-c7a8" hidden="false">
          <description>For all intents and purposes the Avatar is a Daemon and will therefore be affected by weapons and abilities that affect Daemons. He benefits from a 4+ Invulnerable Save as well as his 3+ Armour Save.</description>
        </rule>
        <rule name="Inspiring" id="69d3-3172-3c48-b59f" hidden="false">
          <description>Any Eldar unit with a model within 12&quot; of the Avatar becomes Fearless.</description>
        </rule>
        <rule name="Molten Body" id="4002-407e-376b-c7af" hidden="false">
          <description>Melta weapons, flamers and heavy flamers cannot wound the Avatar.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Fearless" id="fbc8-5390-b03d-d26d" hidden="false" type="rule" targetId="db33-1068-512b-6958"/>
      </infoLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="The Wailing Doom" hidden="false" id="3e0c-60a2-f5cb-1999">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="0a49-d21a-b0c9-18b2-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0a49-d21a-b0c9-18b2-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="The Wailing Doom" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="2177-39b3-421c-aa0d">
              <characteristics>
                <characteristic name="Range" typeId="52616e676523232344415441232323">12&quot;</characteristic>
                <characteristic name="Strength" typeId="537472656e67746823232344415441232323">8</characteristic>
                <characteristic name="AP" typeId="4.1502323234441545e+23">1</characteristic>
                <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1, Melta</characteristic>
                <characteristic name="Info" typeId="33e9-27bd-77e4-401d">The Wailing Doom is a weapon of immense power that may take the form of a vicious spear, a mighty sword, or a many-bladed axe. It can be used to project a nimbus of burning psychic energy, with the listed profile.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
