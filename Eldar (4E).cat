              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A vehicle with star engines may move an additional 12&quot; in lieu of shooting, but troops may not embark or disembark that turn.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditions>
                <condition type="instanceOf" value="1" field="selections" scope="parent" childId="5a71-9aa6-3c91-983d" shared="true" childName="War Walker Squadron"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e878-2723-4144-2682" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
