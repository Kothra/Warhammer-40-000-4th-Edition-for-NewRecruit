        <selectionEntry type="upgrade" import="true" name="Pathfinders" hidden="false" id="ac26-51bd-940d-29d9">
          <rules>
            <rule name="Pathfinders" id="3d68-327f-763d-92ce" hidden="false">
              <description>A Ranger squad that has been upgraded to Pathfinders may ignore difficult terrain. They have the Scouts special rule. Any cover save they use is improved by +2 instead of the usual +1 conferred by the Stealth rule.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink name="Scouts" id="56dd-01a7-d224-daa6" hidden="false" type="rule" targetId="ec7c-9e8c-06ac-06b7"/>
