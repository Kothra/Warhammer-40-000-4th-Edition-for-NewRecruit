      <rules>
        <rule name="Divination" id="c35b-5e5a-b2d6-0434" hidden="false">
          <description>After both sides have deployed at the start of a game, the Eldar player may reposition D3+1 units in his army. No unit may be moved outside of its deployment zone.</description>
        </rule>
      </rules>
