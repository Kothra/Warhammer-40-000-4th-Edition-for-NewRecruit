        <profile name="Wave Serpent" typeId="307d-047f-ca13-706b" typeName="Transport" hidden="false" id="eba0-4bd5-bb22-dcfd">
          <characteristics>
            <characteristic name="Capacity" typeId="8285-4205-b6cd-8473">12 infantry, or 5 Wrathguard and 2 characters</characteristic>
            <characteristic name="Fire Points" typeId="b270-a7f9-22b2-3702">None</characteristic>
            <characteristic name="Access Points" typeId="d17b-0342-b1dc-b8e7">Rear</characteristic>
          </characteristics>
        </profile>
        <profile name="Wave Serpent" typeId="56656869636c6523232344415441232323" typeName="Vehicle" hidden="false" id="bf0a-0d36-9817-1e37">
          <characteristics>
            <characteristic name="Front" typeId="46726f6e7423232344415441232323">12</characteristic>
            <characteristic name="Side" typeId="5.369646523232344e+27">12</characteristic>
            <characteristic name="Rear" typeId="5.265617223232345e+27">10</characteristic>
            <characteristic name="BS" typeId="a6a5-1595-da9e-6155">3</characteristic>
            <characteristic name="Type" typeId="5.479706523232345e+27">Tank, Fast, Skimmer</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Energy Field" id="2899-7515-76e3-92c7" hidden="false">
          <description>Any ranged attack against the Wave Serpent from the front or side arc with a Strength of greater than 8 counts as S8. In addition, all ranged attacks never roll more than +1D6 for their armour penetration (for example, Melta weapons at half range or ordance only roll one dice). Attacks in close combat, or from the rear, are unaffected by the energy field rule.</description>
        </rule>
      </rules>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fd84-1436-ed9c-6910" includeChildSelections="false"/>
      </constraints>
