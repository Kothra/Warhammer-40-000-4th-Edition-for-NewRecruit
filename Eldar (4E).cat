                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with a shimmershield, and all members of his unit, will benefit from a 5+ Invulnerable Save in close combat.</characteristic>
                      </characteristics>
