                <selectionEntry type="upgrade" import="true" name="Shuriken Pistol &amp; Biting Blade" hidden="true" id="6679-47e4-615c-bdd3" sortIndex="3">
                  <profiles>
                    <profile name="Biting Blade" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="8db7-990b-3f9e-0ae2">
                      <characteristics>
                        <characteristic name="Details" typeId="acf3-d214-6e51-29fe">The biting blade is a two-handed close combat weapon that adds +1S. Furthermore, each hit scored by a model with a biting blade adds a further +1S for the purposes of resolving those attacks. For instance, an Exarch who hits three times will strike at S7.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
