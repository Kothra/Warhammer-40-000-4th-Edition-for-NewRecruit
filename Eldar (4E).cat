              <rules>
                <rule name="Fast Shot" id="7513-0bd2-6017-313b" hidden="false">
                  <description>The Exarch may add +1 to the number of shots fired by his weapon (so, for example, Heavy 2 becomes Heavy 3). Fast Shot may not be used by an Exarch in the same turn as he uses Crack Shot.</description>
                </rule>
