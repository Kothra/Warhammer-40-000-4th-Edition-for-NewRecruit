              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Eldrad&apos;s rune armour grants him a 3+ Invulnerable Save.</characteristic>
              </characteristics>
            </profile>
          </profiles>
