      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Staff of Ulthamar" hidden="false" id="f837-fe5a-a636-bfa4" sortIndex="2">
          <profiles>
            <profile name="Staff of Ulthamar" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="78d0-ffb3-dba2-231e">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">If Eldrad is not in an assault, the Staff allows Eldrad to use a third psychic power per turn, which may be a psychic power he has already used that turn. If used as a close combat weapon it always wounds on a roll of 2+ and ignores Armour Saves.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
