                      <characteristics>
                        <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Chainsabres are paired with gauntlets that hosue twin-linked shuriken pistols. A model with chainsabres has +1 Attack and can re-roll all failed to-hit and wound rolls.</characteristic>
                      </characteristics>
                    </profile>
