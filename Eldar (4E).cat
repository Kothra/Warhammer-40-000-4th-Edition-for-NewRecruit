                      <characteristics>
                        <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A diresword is a power weapon. In addition, if a model suffers any unsaved wounds from a diresword, it must immediately pass a Leadership test for each wound suffered. If any of these tests are failed, the victim dies immediately and is removed regardless of remaining wounds.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e0d0-7cf2-3fb9-10dd" includeChildSelections="false"/>
                  </constraints>
