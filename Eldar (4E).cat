          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Wraithcannon" hidden="false" id="8dcd-f98c-7c42-de21">
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="a00f-c260-8bbf-a7f0-min" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a00f-c260-8bbf-a7f0-max" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Wraithcannon" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="ca7c-ec65-7427-1c5b">
                  <characteristics>
                    <characteristic name="Range" typeId="52616e676523232344415441232323">12&quot;</characteristic>
                    <characteristic name="Strength" typeId="537472656e67746823232344415441232323">X</characteristic>
                    <characteristic name="AP" typeId="4.1502323234441545e+23">2</characteristic>
                    <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1</characteristic>
                    <characteristic name="Info" typeId="33e9-27bd-77e4-401d">The wraithcannon always wounds on a roll of 2+, and a roll wound of 6 inflicts instant death on the victim (regardless of its Toughness value). Against targets with an Armour Value, a wraithcannon always inflicts a glancing hit on a roll of 3 or 4 and a penetrating hit on a 5 or 6.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
          <profiles>
            <profile name="Wraithguard" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="7857-c3a0-f64f-70ed">
