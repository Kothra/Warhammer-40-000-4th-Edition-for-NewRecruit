          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">This is a one-handed weapon that adds +1S to the model&apos;s attacks.
In NewRecruit this modifier is applied to the profile automatically.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
