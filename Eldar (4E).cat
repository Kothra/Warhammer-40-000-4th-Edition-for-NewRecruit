        <profile name="Haywire Grenades" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6341-5511-2e06-1542">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Haywire grenades are used for melee attacks against vehicles.
A model attacking with Haywire grenades may only make a single attack. If it hits, roll a D6 to determine the effect:
1 = no effect
2-5 = glancing hit
6 = penetrating hit</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
