                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="equalTo" value="0" field="selections" scope="parent" childId="5236-c5b9-a3e7-ff2b" shared="true" childName="The Changeling"/>
                        <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="5236-c5b9-a3e7-ff2b" shared="true" childName="The Changeling" includeChildSelections="true"/>
                      </conditions>
