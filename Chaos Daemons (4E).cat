<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue library="false" id="8bb0-7df6-5c1b-548b" name="Chaos Daemons (4E)" gameSystemId="sys-b41a-8226-286b-0dea" gameSystemRevision="3" revision="1" authorName="Kothra" battleScribeVersion="2.03" type="catalogue" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Boon of Mutation" hidden="false" id="0d71-eaed-172c-4858">
      <profiles>
        <profile name="Boon of Mutation" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a9d9-26cd-2675-1dc8">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Boon of Mutation is a ranged weapon, but the Daemon may be in combat at the time it uses it, as may the target. Pick any one enemy model (no line of sight is required) and roll to hit. If a hit is scored and the target is found to be within 6&quot; of the Daemon, the target must immediately take a Toughness test. If the test is failed, the target is removed as a casualty. Note that, as no wounds are taken, no saves apply. Models without a Toughness characteristic can not be affected.
If the player using this power has a Chaos Spawn model available, he may replace the victim with a Spawn. The Spawn is immediately under the Chaos player&apos;s control (and is worth 40 Victory Points if killed). If the model was in base contact with friendly models, they are now engaged in combat with the Spawn.</characteristic>
          </characteristics>
        </profile>
        <profile name="Chaos Spawn" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="ac01-e5b5-0c61-7180">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Beast</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">3</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">0</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">5</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">5</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">3</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">3</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">D6</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">-</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Breath of Chaos" hidden="false" id="ceb9-9f91-1b3e-3c52">
      <profiles>
        <profile name="Breath of Chaos" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="406b-7f01-4fa7-3771">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Breath of Chaos is a Template weapon. Any models fully or partially under the template suffer one wound on a D6 roll of 4+, with no Armour or Cover saves allowed. Vehicles touched by the template suffer a glancing hit on a D6 roll of 4+.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Chaos Icon" hidden="false" id="6d37-84e2-4a0e-d773">
      <profiles>
        <profile name="Chaos Icon" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4cbb-327c-a981-9b27">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">When a friendly unit Deep Strikes within 6&quot; of an Icon of Chaos it does not roll for scatter, provided that the icon was on the table from the beginning of the turn and has not arrived from Reserve in the same turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Iron Hide" hidden="false" id="688d-0d5a-03e0-af30">
      <profiles>
        <profile name="Iron Hide" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="2818-d625-c4a0-41fd">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with Iron Hide receive a 3+ Armour Save.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="set" value="3+" field="5.361766523232344e+27" affects="profiles.Unit" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Daemonic Flight" hidden="false" id="dcec-203c-21d3-11a1">
      <profiles>
        <profile name="Daemonic Flight" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="33ac-7f21-e246-381b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with Daemonic Flight move like Jump Infantry.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="replace" value="Jump Infantry" field="556e6974205479706523232344415441232323" affects="profiles.Unit" arg="Infantry"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Daemonic Gaze" hidden="false" id="1591-7af3-83cd-01dc">
      <profiles>
        <profile name="Daemonic Gaze" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="a14e-ee0e-1257-99ba">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">24&quot;</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">5</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">3</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 3</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d"/>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Unholy Might" hidden="false" id="d05b-e0c2-21b4-241e">
      <profiles>
        <profile name="Unholy Might" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0ae4-a44f-3983-4451">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with Unholy Might has +1 Strength.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="increment" value="1" field="5.323232344415441e+21" affects="profiles.Unit"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Instrument of Chaos" hidden="false" id="e3e1-0578-8ec9-4999">
      <profiles>
        <profile name="Instrument of Chaos" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="54da-e20e-1d5d-17eb">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">If the model with an Instrument of Chaos is involved in a fight which results in a draw, its side counts as having won by one wound. If both sides have an Instrument of Chaos the result remains a draw.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Blessing of the Blood God" hidden="false" id="bae7-42d2-496e-53b1">
      <profiles>
        <profile name="Blessing of the Blood God" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="7455-32ca-9f89-cd0f">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The model with this blessing has a 2+ Invulnerable Save against wounds caused by psychic powers or force weapons.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Death Strike" hidden="false" id="0d72-e1ac-d843-5188">
      <profiles>
        <profile name="Death Strike" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="95b6-ff47-8bad-7093">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">12&quot;</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">7</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">2</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d"/>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Fury of Khorne" hidden="false" id="9b4c-1566-bafe-f471">
      <profiles>
        <profile name="Fury of Khorne" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="1152-58d2-10dc-03d3">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The close combat attacks of a model gifted with the Fury of Khorne gain the Rending special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Rending" id="72b3-e429-9291-07ef" hidden="false" type="rule" targetId="b4f7-137b-d90e-4ac9"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Hellblade" hidden="false" id="991c-08f6-12d0-531e">
      <profiles>
        <profile name="Hellblade" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="7c95-7489-fa14-8307">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Hellblades are power weapons.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Bolt of Tzeentch" hidden="false" id="3742-a9ff-37b8-12e7">
      <profiles>
        <profile name="Bolt of Tzeentch" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="0959-9b4c-53db-955a">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">24&quot;</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">8</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">1</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 1</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d"/>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Master of Sorcery" hidden="false" id="8b18-db42-3dcd-a1ac">
      <profiles>
        <profile name="Master of Sorcery" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="9247-f832-f78a-b511">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The model with this gift can use one extra ranged weapon in its Shooting phases (but not the same one twice).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Soul Devourer" hidden="false" id="768a-4d34-8654-18f9">
      <profiles>
        <profile name="Soul Devourer" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="d472-d14f-8fb4-30e9">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The model with this counts as armed with a power weapon. In addition, if a model suffers any wounds from the Daemon&apos;s close combat attacks, it must immediately take a Leadership test for each wound suffered (on its own Leadership value, the model cannot use another mode&apos;s Ld for this test). If any of these tests are failed, the model suffers instant death.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Pavane of Slaanesh" hidden="false" id="c0e2-cd1e-672a-fecf">
      <profiles>
        <profile name="Pavane of Slaanesh" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="277e-0ea8-9fd0-847e">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Pavane of Slaanesh is a ranged weapon with a range of 18&quot;. Roll to hit as normal. If the target unit is hit, the firer can immediately move the target unit up to D6&quot;. This movement follows the same rules as a normal move, except that it is not slowed by difficult terrain. Dangerous terrain tests are taken as normal, victims may not be moved off the table, out of combat, into impassable terrain or to within 1&quot; of enemy models, and so on. An enemy unit may only be moved with this gift once per turn, successive hits have no effect. The Pavane has no effect on vehicles other than walkers.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Aura of Acquiescence" hidden="false" id="1627-c549-4180-bdd6">
      <profiles>
        <profile name="Aura of Acquiescence" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="7164-7543-b163-b2ea">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with this gift count as equipped with both assault grenades (when charging an enemy in cover, fight at Initiative 10 - same as defender) and defensive grenades (enemy gains no bonus for charging this unit) (but receive no Strength bonus in close combat against vehicles).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Aura of Decay" hidden="false" id="b515-40b9-adc1-733a">
      <profiles>
        <profile name="Aura of Decay" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="884b-1b45-2ff8-8d09">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Aura of Decay is a ranged weapon, but the Daemon maybe in close combat at the time it uses it, as may the targets. When used, all enemy models within 6&quot; of the Daemon automatically suffer a Strength 2 hit with AP - (roll to hit as normal).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Cloud of Flies" hidden="false" id="c5f9-599a-1131-4238">
      <profiles>
        <profile name="Cloud of Flies" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0e85-90ed-df0b-d152">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with this gift count as equipped with both assault grenades (when charging an enemy in cover, fight at Initiative 10 - same as defender) and defensive grenades (enemy gains no bonus for charging this unit) (but receive no Strength bonus in close combat against vehicles).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Noxious Touch" hidden="false" id="c6db-a991-aefd-40a6">
      <profiles>
        <profile name="Noxious Touch" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="c36f-9e96-88ac-985d">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">The Daemon&apos;s close combat attacks are poisoned, wounding on a 2+.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Transfixing Gaze" hidden="false" id="d6f4-8028-4904-7437">
      <profiles>
        <profile name="Transfixing Gaze" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="cb73-5d63-59e5-7923">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The player may force one model in base contact with the Daemon to lose an Attack in close combat.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Soporific Musk" hidden="false" id="7d31-b31b-563a-f9ab">
      <profiles>
        <profile name="Sporific Musk" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="79b6-deee-c549-5c04">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Daemon has the Hit &amp; Run special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Hit &amp; Run" id="43f0-4674-8c11-abc6" hidden="false" type="rule" targetId="79a9-ed86-80c5-a94a"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Rending Claws" hidden="false" id="a95d-8242-d435-7bc0">
      <profiles>
        <profile name="Rending Claws" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="0742-06a7-b74b-fffd">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Rending Claws are a pair of rending close combat weapons (the bonus attack is always included in the Daemon&apos;s profile).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="We Are Legion" hidden="false" id="0f81-2bd1-441d-35d2">
      <profiles>
        <profile name="We Are Legion" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c99a-2ab0-4bb1-bb70">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">During the Shooting phase, the Daemon does not have to target all of its ranged weapons against the same target. Instead, it may fire any of its weapons at a different target (declare all targets before rolling to hit). It can then choose to assault any of the enemies it has fired against.


If the Daemon is an Independent Character and joins a unit, it can choose different targets from its unit&apos;s. Note that the unit is not affected by the shooting of the character in regards to which enemy they can assault in the ensuing Assault phase.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Warpfire" hidden="false" id="4082-a40e-7132-cab2">
      <profiles>
        <profile name="Warpfire" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="42b9-ae14-9edb-9e7d">
          <characteristics>
            <characteristic name="Range" typeId="52616e676523232344415441232323">18&quot;</characteristic>
            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">4</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">4</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault 3</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d"/>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Chariot of Khorne" hidden="false" id="4bad-e3ef-5818-df32">
      <profiles>
        <profile name="Chariot of Khorne" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a0f2-f41f-818f-06a5">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">This mount grants the rider +1 Strength, +1 Toughness, +2 Wounds, +1 Attack, and the Iron Hide gift. In addition, the rider loses the Independent Character rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Iron Hide" id="0d35-3405-0bbf-3f26" hidden="false" type="profile" targetId="2818-d625-c4a0-41fd"/>
      </infoLinks>
      <modifiers>
        <modifier type="increment" value="1" field="5.323232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="set" value="3+" field="5.361766523232344e+27" affects="profiles.Unit" scope="parent"/>
        <modifier type="increment" value="1" field="5.423232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="increment" value="2" field="5.723232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="increment" value="1" field="4.123232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="replace" value="" field="556e6974205479706523232344415441232323" affects="recursive.profiles.Unit" arg=", Character" scope="parent"/>
      </modifiers>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Chariot of Slaanesh" hidden="false" id="eedb-1069-d587-9409">
      <profiles>
        <profile name="Chariot of Slaanesh" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="52fe-ec19-ec33-ac6f">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">This mount grants the rider +1 Toughness, +3 Wounds, +2 Attacks, a 4+ Armour Save, and changes its unit type to Cavalry. In addition, the rider loses the Independent Character rule but gains the Furious Charge special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="increment" value="1" field="5.423232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="increment" value="3" field="5.723232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="increment" value="2" field="4.123232344415441e+21" affects="profiles.Unit" scope="parent"/>
        <modifier type="replace" value="" field="556e6974205479706523232344415441232323" affects="profiles.Unit" arg=", Character" scope="parent"/>
        <modifier type="set" value="4+" field="5.361766523232344e+27" affects="profiles.Unit" scope="parent"/>
        <modifier type="replace" value="Cavalry" field="556e6974205479706523232344415441232323" affects="profiles.Unit" scope="parent" arg="Infantry"/>
      </modifiers>
      <infoLinks>
        <infoLink name="Furious Charge" id="aef0-f6e3-dde5-9845" hidden="false" type="rule" targetId="d9b8-5d21-f44f-80d3"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Juggernaut of Khorne" hidden="false" id="addc-34e0-c950-61d4">
      <profiles>
