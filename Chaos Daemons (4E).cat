              <rules>
                <rule name="Watch this!" id="c761-fe0e-43aa-0adc" hidden="false">
                  <description>In the Shooting phase, before using their second ranged attack, roll a dice. On a 4-6 they proceed as normal. On a 1-3 they will use once again the same power they have just used.</description>
                </rule>
              </rules>
